{
    "name": "hoshimi-bot",
    "version": "1.0.0",
    "description": "A example bot to show how to use hoshimi",
    "main": "./src/index.ts",
    "type": "module",
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
    "keywords": [],
    "author": "Ganyu Studios",
    "license": "MIT",
    "lint-staged": {
        "*.{ts,json}": [
            "pnpm format"
        ]
    },
    "contributors": [
        {
            "url": "https://github.com/EvilG-MC",
            "name": "JustEvil (EvilG-MC)"
        }
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "start": "tsx ./src/index.ts",
        "dev": "tsx ./src/index.ts --debug",
        "lint": "biome lint --write .",
        "format": "biome format --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "hoshimi": "0.3.10-dev-24875946063.0",
        "meowdb": "^2.2.3",
        "redis": "^5.12.1",
        "seyfert": "github:tiramisulabs/seyfert",
        "yunaforseyfert": "github:SagiriIkeda/yunaforseyfert"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@types/node": "^25.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@biomejs/biome",
            "esbuild",
            "seyfert",
            "yunaforseyfert"
        ],
        "overrides": {
            "hoshimi": "link:../../../../AppData/Local/pnpm/global/5/node_modules/hoshimi"
        }
    }
}
